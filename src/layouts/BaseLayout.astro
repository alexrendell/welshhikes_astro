---
const { title } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  
  <!-- Browser tab icon -->
  <link rel="icon" type="image/png" href="/images/welshhikes_logo_large.png" />
  
  <!-- iPhone/iPad home screen icon -->
  <link rel="apple-touch-icon" href="/images/welshhikes_logo_large.png" />
  
  <!-- Android home screen / Chrome -->
  <link rel="shortcut icon" href="/images/welshhikes_logo_large.png" />
</head>
<body>

  <nav class="topbar">
    <div class="topbar-content">
      <a href="/" class="logo">
        <img src="/images/welshhikes_logo_large.png" alt="Welsh Hikes logo" class="logo-img" />
        Welsh Hikes
      </a>
      <ul class="nav-links">
        <li><a href="/about">About</a></li>
        <li><a href="/game">Game</a></li>
        <li><a href="/projects">Projects</a></li>
      </ul>
    </div>
  </nav>

  <slot />

</body>
</html>

<style>
  body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: white;
  }

  .topbar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    padding: 20px 40px;
    background: rgba(0, 0, 0, 0);
    color: white;
    z-index: 10;
    display: flex;
    justify-content: center;
    font-family: Helvetica, Arial, sans-serif;
    box-sizing: border-box;
  }

  .topbar-content {
    width: 100%;
    max-width: 1200px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    text-decoration: none;
    color: white;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-img {
    width: 38px;
    height: 38px;
    border-radius: 50%;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 30px;
    margin: 0;
    padding: 0;
  }

  .nav-links li a {
    text-decoration: none;
    color: white;
    font-size: 1rem;
    transition: opacity 0.3s ease;
  }

  .nav-links li a:hover {
    opacity: 0.7;
  }
</style>