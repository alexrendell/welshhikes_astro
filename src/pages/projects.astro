---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Projects - Alex Rendell">

  <!-- Hero -->
  <div class="projects-hero">
    <div class="projects-hero-inner">
      <p class="eyebrow">Selected Work</p>
      <h1>Projects</h1>
      <p class="subtitle">Machine learning, software engineering, and things built out of curiosity.</p>
    </div>
  </div>

  <div class="projects-wrapper">

    <!-- Featured Project -->
    <section class="featured-section">
      <p class="label">Featured Project</p>
      <div class="featured-card">

        <div class="featured-image">
          <div class="image-placeholder">
            <span>Screenshot / Demo</span>
          </div>
        </div>

        <div class="featured-content">
          <div class="featured-top">
            <h2>Adversarial Machine Learning UI</h2>
            <p class="featured-desc">
              My Masters dissertation explored adversarial attacks on machine learning models — 
              inputs deliberately crafted to fool a classifier. To make the research accessible, 
              I built a clean interactive UI hosted on Hugging Face Spaces, letting anyone 
              experiment with the concepts without needing to touch any code.
            </p>
            <p class="featured-result">
              🏆 Distinction — deployed as a live Hugging Face Space
            </p>
          </div>

          <div class="tech-stack">
            <span class="tag">Python</span>
            <span class="tag">PyTorch</span>
            <span class="tag">Gradio</span>
            <span class="tag">Hugging Face</span>
            <span class="tag">Adversarial ML</span>
          </div>

          <div class="featured-links">
            <a href="https://huggingface.co/" target="_blank" class="btn btn-primary">
              View on Hugging Face
            </a>
            <a href="#" class="btn btn-secondary">
              GitHub
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- Projects Grid -->
    <section class="grid-section">
      <p class="label">Other Projects & Research</p>
      <div class="projects-grid">

        <!-- Masters Dissertation -->
        <div class="project-card">
          <div class="card-top">
            <span class="card-type">Research</span>
            <h3>Masters Dissertation</h3>
            <p>
              A deep dive into adversarial robustness in neural networks. 
              Investigated attack vectors and defence strategies across 
              image classification tasks.
            </p>
          </div>
          <div class="card-bottom">
            <div class="card-tags">
              <span class="tag small">PyTorch</span>
              <span class="tag small">Deep Learning</span>
              <span class="tag small">Computer Vision</span>
            </div>
            <span class="card-badge distinction">Distinction</span>
          </div>
        </div>

        <!-- Bachelors Dissertation -->
        <div class="project-card">
          <div class="card-top">
            <span class="card-type">Research</span>
            <h3>Bachelors Dissertation</h3>
            <p>
              Placeholder — add your Bachelors dissertation title and a 
              short description of what you built or investigated here.
            </p>
          </div>
          <div class="card-bottom">
            <div class="card-tags">
              <span class="tag small">Add</span>
              <span class="tag small">Your</span>
              <span class="tag small">Stack</span>
            </div>
            <span class="card-badge">First Class</span>
          </div>
        </div>

        <!-- Placeholder for Welsh Hikes -->
        <div class="project-card">
          <div class="card-top">
            <span class="card-type">Web</span>
            <h3>Welsh Hikes</h3>
            <p>
              A personal blog and portfolio site built with Astro, 
              documenting hikes across Wales and the UK alongside 
              personal projects.
            </p>
          </div>
          <div class="card-bottom">
            <div class="card-tags">
              <span class="tag small">Astro</span>
              <span class="tag small">CSS</span>
              <span class="tag small">JavaScript</span>
            </div>
            <a href="/" class="card-link">Visit Site →</a>
          </div>
        </div>

      </div>
    </section>

  </div>

</BaseLayout>

<style>
  /* Hero */
  .projects-hero {
    background-color: #003366;
    padding: 120px 20px 70px;
    text-align: center;
  }

  .projects-hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.5);
    margin: 0 0 12px 0;
    font-family: Helvetica, Arial, sans-serif;
  }

  .projects-hero h1 {
    font-size: 3.5rem;
    font-family: Helvetica, Arial, sans-serif;
    color: white;
    margin: 0 0 16px 0;
    font-weight: bold;
  }

  .subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.65);
    margin: 0;
    line-height: 1.6;
    font-family: Arial, sans-serif;
  }

  /* Wrapper */
  .projects-wrapper {
    background-color: #f9f9f9;
    padding: 60px 20px 80px;
    box-sizing: border-box;
  }

  .label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #888;
    margin: 0 0 20px 0;
    font-family: Helvetica, Arial, sans-serif;
  }

  /* Featured */
  .featured-section {
    max-width: 1100px;
    margin: 0 auto 70px;
  }

  .featured-card {
    display: flex;
    gap: 50px;
    align-items: flex-start;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    padding: 40px;
    border-left: 4px solid #003366;
  }

  .featured-image {
    flex: 0 0 340px;
  }

  .image-placeholder {
    width: 100%;
    height: 220px;
    background: #eef2f7;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #aab;
    font-size: 0.9rem;
    font-family: Arial, sans-serif;
    border: 2px dashed #ccd;
  }

  .featured-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .featured-content h2 {
    font-size: 1.7rem;
    font-family: Helvetica, Arial, sans-serif;
    color: #003366;
    margin: 0 0 12px 0;
  }

  .featured-desc {
    font-size: 1rem;
    line-height: 1.75;
    color: #444;
    margin: 0 0 10px 0;
    font-family: Arial, sans-serif;
  }

  .featured-result {
    font-size: 0.9rem;
    color: #4a7c59;
    font-weight: bold;
    margin: 0;
    font-family: Arial, sans-serif;
  }

  /* Tags */
  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    background: #eef2f7;
    color: #003366;
    font-size: 0.82rem;
    padding: 5px 12px;
    border-radius: 20px;
    font-family: Arial, sans-serif;
    font-weight: bold;
  }

  .tag.small {
    font-size: 0.75rem;
    padding: 4px 10px;
  }

  /* Buttons */
  .featured-links {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn {
    padding: 11px 22px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: Helvetica, Arial, sans-serif;
    text-decoration: none;
    transition: all 0.2s ease;
    font-weight: bold;
  }

  .btn-primary {
    background-color: #003366;
    color: white;
  }

  .btn-primary:hover {
    background-color: #00509e;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: white;
    color: #003366;
    border: 2px solid #003366;
  }

  .btn-secondary:hover {
    background-color: #003366;
    color: white;
    transform: translateY(-2px);
  }

  /* Grid */
  .grid-section {
    max-width: 1100px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .project-card {
    background: white;
    border-radius: 12px;
    padding: 28px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border-top: 3px solid #eef2f7;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    border-top-color: #003366;
  }

  .card-type {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4a7c59;
    font-family: Helvetica, Arial, sans-serif;
    font-weight: bold;
    display: block;
    margin-bottom: 8px;
  }

  .project-card h3 {
    font-size: 1.15rem;
    font-family: Helvetica, Arial, sans-serif;
    color: #003366;
    margin: 0 0 10px 0;
  }

  .project-card p {
    font-size: 0.92rem;
    line-height: 1.7;
    color: #555;
    margin: 0;
    font-family: Arial, sans-serif;
  }

  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .card-badge {
    font-size: 0.75rem;
    font-weight: bold;
    padding: 4px 10px;
    border-radius: 20px;
    background: #eef2f7;
    color: #003366;
    font-family: Arial, sans-serif;
    white-space: nowrap;
  }

  .card-badge.distinction {
    background: #e8f4ec;
    color: #4a7c59;
  }

  .card-link {
    font-size: 0.85rem;
    color: #003366;
    font-weight: bold;
    text-decoration: none;
    font-family: Arial, sans-serif;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .projects-hero h1 {
      font-size: 2.2rem;
    }

    .featured-card {
      flex-direction: column;
      padding: 24px;
    }

    .featured-image {
      flex: 0 0 auto;
      width: 100%;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>