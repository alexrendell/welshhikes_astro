---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="About - Welsh Hikes">

  <header class="hero">
    <div class="hero-overlay">
      <h1>About Me</h1>
    </div>
  </header>

  <div class="about-wrapper">
    <div class="about-container">
      <div class="about-text">
        <p class="who-label">Who Am I</p>
        <h1 class="name">Alex Rendell</h1>
        <p>
          I've spent my entire life hiking and exploring my home country of Wales. 
          What started as a personal passion has grown into this site. A place to 
          share my adventures across Wales and the wider UK, and hopefully something 
          others find useful along the way.
        </p>
        <p>
          Through my blog I hope to cover all aspects of life on the trail. From 
          detailed hike write-ups and hidden viewpoints, to the best activities and 
          places worth making the trip for. In time I plan to add proper travel guides 
          and original photography that does justice to the landscapes I've been lucky 
          enough to explore.
        </p>
        <p>
          Beyond hiking, this site doubles as a home for my projects and passions. 
          I hold a Masters in Computer Science and I'm always working on something new — 
          whenever a project feels ready, it'll find its way here.
        </p>
      </div>
      <div class="about-photo">
        <img src="/images/alex_about_main.jpeg" alt="Alex Rendell" />
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .hero {
    height: 30vh;
    min-height: 400px;
    background-image: url("/images/about_hero.jpeg");
    background-size: cover;
    background-position: center 70%;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom-left-radius: 50% 8%;
    border-bottom-right-radius: 50% 8%;
    overflow: hidden;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.25);
    z-index: 1;
  }

  .hero-overlay {
    padding: 40px 60px;
    text-align: center;
    z-index: 2;
    position: relative;
  }

  .hero h1 {
    color: white;
    font-size: 3.5rem;
    font-family: Helvetica, Arial, sans-serif;
    margin: 0;
  }

  .about-wrapper {
    min-height: 100vh;
    padding: 60px 20px 60px;
    background-color: #f9f9f9;
    box-sizing: border-box;
  }

  .about-container {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }

  .about-text {
    flex: 1;
  }

  .who-label {
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #888;
    margin: 0 0 8px 0;
    font-family: Helvetica, Arial, sans-serif;
  }

  .name {
    font-size: 2.8rem;
    font-weight: bold;
    color: #003366;
    margin: 0 0 28px 0;
    font-family: Helvetica, Arial, sans-serif;
  }

  .about-text p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #333;
    margin-bottom: 20px;
    font-family: Arial, sans-serif;
  }

  .about-photo {
    flex: 0 0 420px;
  }

  .about-photo img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .about-container {
      flex-direction: column;
    }
    .about-photo {
      flex: 0 0 auto;
      width: 100%;
    }
    .name {
      font-size: 2rem;
    }
  }
</style>