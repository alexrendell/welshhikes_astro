---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Welsh Hikes">

  <header class="hero">
    <div class="hero-overlay">
      <h1>The Welsh Hiking Experience</h1>
    </div>
  </header>

  <div class="page-container">

    <h2 class="section-title">Latest Posts</h2>

    <div class="posts-grid">
      <a href="/blog/four-waterfalls" class="post-card">
        <img src="/images/four_waterfalls_large_waterfall.jpeg" alt="Four Waterfalls Walk" class="fourwaterfalls-card-img" />
        <div class="post-card-body">
          <div class="post-meta">
            <span>📍 Brecon Beacons</span>
            <span>📏 9km</span>
            <span>⏱ 3 hrs</span>
          </div>
          <h3>Four Waterfalls Walk</h3>
          <p>A classic waterfall route through the Brecon Beacons, building to a gigantic final waterfall you can walk beneath.</p>
          <span class="read-more">Read more →</span>
        </div>
      </a>

      <a href="/blog/sugarloaf" class="post-card">
        <img src="/images/abergavenny_view_park.jpeg" alt="Sugarloaf Mountain" class="sugarloaf-card-img" />
        <div class="post-card-body">
          <div class="post-meta">
            <span>📍 Abergavenny</span>
            <span>📏 10km</span>
            <span>⛺ Camping</span>
          </div>
          <h3>Sugarloaf Mountain & Camping</h3>
          <p>A late summer camping trip to Abergavenny with a climb up the unmissable Sugarloaf Mountain and evenings by the fire.</p>
          <span class="read-more">Read more →</span>
        </div>
      </a>
      
      <a href="/blog/dees-fishing" class="post-card">
        <img src="/images/dees1.jpg" alt="Dee's Fishing Ponds" />
        <div class="post-card-body">
          <div class="post-meta">
            <span>📍 Ynysybwl</span>
            <span>🎣 Fishing</span>
            <span>💷 £7.50</span>
          </div>
          <h3>Dee's Fishing Ponds</h3>
          <p>A rainy early summer day at a hidden gem of a fishing spot tucked inside a working farm in Ynysybwl.</p>
          <span class="read-more">Read more →</span>
        </div>
      </a>

    </div>

  </div>

</BaseLayout>

<style>
  .hero {
    height: 30vh;
    min-height: 400px;
    background-image: url("/images/brecon_index_hero.jpeg");
    background-size: cover;
    background-position: center 70%;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom-left-radius: 50% 8%;
    border-bottom-right-radius: 50% 8%;
    overflow: hidden;
    position: relative;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.25);
    z-index: 1;
  }

  .hero-overlay {
    padding: 40px 60px;
    text-align: center;
    z-index: 2;
    position: relative;
  }

  .hero h1 {
    color: white;
    font-size: 3.5rem;
    font-family: Helvetica, Arial, sans-serif;
    margin: 0;
  }

  .page-container {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .section-title {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 1.6rem;
    color: #003366;
    margin-bottom: 24px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }

  .post-card {
    text-decoration: none;
    color: inherit;
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: block;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }

  .post-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .sugarloaf-card-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    object-position: center 30%;
  }

  .fourwaterfalls-card-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    object-position: center 60%;
  }

  .post-card-body {
    padding: 20px;
  }

  .post-meta {
    display: flex;
    gap: 12px;
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .post-card-body h3 {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 1.3rem;
    color: #003366;
    margin: 0 0 10px 0;
  }

  .post-card-body p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
    margin: 0 0 16px 0;
  }

  .read-more {
    font-size: 0.9rem;
    color: #003366;
    font-weight: bold;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }

    .hero-overlay {
      padding: 20px;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>